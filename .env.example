# Copy to .env and fill in values

# Anthropic (Claude) API — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram — token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_CHAT_ID=987654321

# Supabase — project URL, anon key (reads), service role key (writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_...
SUPABASE_SERVICE_KEY=eyJhbGci...   # Settings → API → service_role
